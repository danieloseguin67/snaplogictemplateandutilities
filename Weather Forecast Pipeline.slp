        "11111111-1111-1111-1111-00000000000a": {
            "class_id": "com-snaplogic-snaps-script-script",
            "class_version": 2,
            "instance_id": "11111111-1111-1111-1111-00000000000a",
            "property_map": {
                "account": {
                    "account_ref": {
                        "value": {}
                    }
                },
                "error": {
                    "error0": {
                        "label": {
                            "value": "error0"
                        },
                        "view_type": {
                            "value": "document"
                        }
                    },
                    "error_behavior": {
                        "value": "fail"
                    }
                },
                "info": {
                    "label": {
                        "value": "Python Excel Generator"
                    },
                    "notes": {
                        "value": ""
                    }
                },
                "input": {
                    "input0": {
                        "label": {
                            "value": "input0"
                        },
                        "view_type": {
                            "value": "document"
                        }
                    }
                },
                "output": {
                    "output0": {
                        "label": {
                            "value": "output0"
                        },
                        "view_type": {
                            "value": "document"
                        }
                    }
                },
                "settings": {
                    "editable_content": {
                        "value": "from com.snaplogic.scripting.language import ScriptHook\nfrom java.io import ByteArrayOutputStream\nfrom java.util.zip import ZipOutputStream, ZipEntry\nfrom java.util import Base64\n\nclass ExcelGeneratorHook(ScriptHook):\n    def __init__(self, input, output, error, log):\n        self.input = input\n        self.output = output\n        self.error = error\n        self.log = log\n\n    def execute(self):\n        records = []\n        read_log = []\n        try:\n            self.log.info(\"ExcelGeneratorHook.execute() started\")\n            doc_count = 0\n            try:\n                for doc in self.input:\n                    try:\n                        record = {}\n                        if hasattr(doc, 'entrySet'):\n                            for entry in doc.entrySet():\n                                key = str(entry.getKey())\n                                val = entry.getValue()\n                                if val is None:\n                                    record[key] = \"\"\n                                else:\n                                    try:\n                                        s = str(val)\n                                        record[key] = float(s) if '.' in s else s\n                                    except Exception:\n                                        record[key] = str(val)\n                        elif isinstance(doc, dict):\n                            for k, v in doc.items():\n                                record[str(k)] = v\n                        else:\n                            for k, v in dict(doc).items():\n                                record[str(k)] = v\n                        records.append(record)\n                        read_log.append({\"line\": doc_count + 1, \"raw\": str(record)[:200]})\n                        doc_count += 1\n                        self.log.info(\"Read record {}: {}\".format(doc_count, str(record)[:100]))\n                    except Exception as rec_err:\n                        read_log.append({\"line\": doc_count + 1, \"raw\": \"ERROR reading record: \" + str(rec_err)})\n                        self.log.warn(\"Error reading record {}: {}\".format(doc_count + 1, str(rec_err)))\n            except Exception as iter_err:\n                self.log.error(\"Error iterating input: \" + str(iter_err))\n                self.error.write({\"status\": \"error\", \"stage\": \"input_iteration\", \"message\": str(iter_err)})\n                return\n\n            self.log.info(\"Total records collected: {}\".format(len(records)))\n\n            try:\n                def xml_escape(val):\n                    return str(val).replace(\"&\", \"&amp;\").replace(\"<\", \"&lt;\").replace(\">\", \"&gt;\").replace('\"',\"&quot;\").replace(\"'\",\"&apos;\")\n\n                def col_letter(idx):\n                    return chr(ord('A') + idx)\n\n                def build_sheet_xml(sheet_name_unused, headers, rows_data):\n                    sheet_rows = []\n                    header_cells = \"\"\n                    for col_idx, hdr in enumerate(headers):\n                        cell_ref = \"{}1\".format(col_letter(col_idx))\n                        header_cells += '<c r=\"{}\" t=\"inlineStr\"><is><t>{}</t></is></c>'.format(cell_ref, xml_escape(hdr))\n                    sheet_rows.append('<row r=\"1\">{}</row>'.format(header_cells))\n                    for row_idx, row_rec in enumerate(rows_data, start=2):\n                        row_cells = \"\"\n                        for col_idx, hdr in enumerate(headers):\n                            cell_ref = \"{}{}\".format(col_letter(col_idx), row_idx)\n                            val = row_rec.get(hdr, \"\") if hasattr(row_rec, 'get') else \"\"\n                            if val is None:\n                                val = \"\"\n                            if hdr == \"Temperature\":\n                                try:\n                                    num_val = float(str(val))\n                                    row_cells += '<c r=\"{}\"><v>{}</v></c>'.format(cell_ref, num_val)\n                                except Exception:\n                                    row_cells += '<c r=\"{}\" t=\"inlineStr\"><is><t>{}</t></is></c>'.format(cell_ref, xml_escape(val))\n                            else:\n                                row_cells += '<c r=\"{}\" t=\"inlineStr\"><is><t>{}</t></is></c>'.format(cell_ref, xml_escape(val))\n                        sheet_rows.append('<row r=\"{}\">{}</row>'.format(row_idx, row_cells))\n                    return (\n                        '<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\\n'\n                        '<worksheet xmlns=\"http://schemas.openxmlformats.org/spreadsheetml/2006/main\">'\n                        '<sheetData>' + \"\".join(sheet_rows) + '</sheetData></worksheet>'\n                    )\n\n                weather_headers = [\"Hour\", \"Temperature\"]\n                sheet1_xml = build_sheet_xml(\"Weather Data\", weather_headers, records)\n\n                rows_read_headers = [\"Line\", \"Row Data\"]\n                rows_read_data = [{\"Line\": str(r[\"line\"]), \"Row Data\": r[\"raw\"]} for r in read_log]\n                sheet2_xml = build_sheet_xml(\"Rows Read\", rows_read_headers, rows_read_data)\n\n            except Exception as build_err:\n                self.log.error(\"Error building sheet XML: \" + str(build_err))\n                self.error.write({\"status\": \"error\", \"stage\": \"build_xml\", \"message\": str(build_err)})\n                return\n\n            try:\n                content_types_xml = (\n                    '<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\\n'\n                    '<Types xmlns=\"http://schemas.openxmlformats.org/package/2006/content-types\">'\n                    '<Default Extension=\"rels\" ContentType=\"application/vnd.openxmlformats-package.relationships+xml\"/>'\n                    '<Default Extension=\"xml\" ContentType=\"application/xml\"/>'\n                    '<Override PartName=\"/xl/workbook.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml\"/>'\n                    '<Override PartName=\"/xl/worksheets/sheet1.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml\"/>'\n                    '<Override PartName=\"/xl/worksheets/sheet2.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml\"/>'\n                    '<Override PartName=\"/xl/styles.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.styles+xml\"/>'\n                    '<Override PartName=\"/docProps/app.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.extended-properties+xml\"/>'\n                    '<Override PartName=\"/docProps/core.xml\" ContentType=\"application/vnd.openxmlformats-package.core-properties+xml\"/>'\n                    '</Types>'\n                )\n\n                rels_xml = (\n                    '<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\\n'\n                    '<Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\">'\n                    '<Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument\" Target=\"xl/workbook.xml\"/>'\n                    '<Relationship Id=\"rId2\" Type=\"http://schemas.openxmlformats.org/package/2006/relationships/metadata/core-properties\" Target=\"docProps/core.xml\"/>'\n                    '<Relationship Id=\"rId3\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/extended-properties\" Target=\"docProps/app.xml\"/>'\n                    '</Relationships>'\n                )\n\n                workbook_xml = (\n                    '<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\\n'\n                    '<workbook xmlns=\"http://schemas.openxmlformats.org/spreadsheetml/2006/main\" '\n                    'xmlns:r=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships\">'\n                    '<sheets>'\n                    '<sheet name=\"Weather Data\" sheetId=\"1\" r:id=\"rId1\"/>'\n                    '<sheet name=\"Rows Read\" sheetId=\"2\" r:id=\"rId2\"/>'\n                    '</sheets></workbook>'\n                )\n\n                workbook_rels_xml = (\n                    '<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\\n'\n                    '<Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\">'\n                    '<Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet\" Target=\"worksheets/sheet1.xml\"/>'\n                    '<Relationship Id=\"rId2\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet\" Target=\"worksheets/sheet2.xml\"/>'\n                    '<Relationship Id=\"rId3\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/styles\" Target=\"styles.xml\"/>'\n                    '</Relationships>'\n                )\n\n                styles_xml = (\n                    '<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\\n'\n                    '<styleSheet xmlns=\"http://schemas.openxmlformats.org/spreadsheetml/2006/main\">'\n                    '<fonts count=\"1\"><font><sz val=\"11\"/><name val=\"Calibri\"/></font></fonts>'\n                    '<fills count=\"2\"><fill><patternFill patternType=\"none\"/></fill><fill><patternFill patternType=\"gray125\"/></fill></fills>'\n                    '<borders count=\"1\"><border><left/><right/><top/><bottom/><diagonal/></border></borders>'\n                    '<cellStyleXfs count=\"1\"><xf numFmtId=\"0\" fontId=\"0\" fillId=\"0\" borderId=\"0\"/></cellStyleXfs>'\n                    '<cellXfs count=\"1\"><xf numFmtId=\"0\" fontId=\"0\" fillId=\"0\" borderId=\"0\" xfId=\"0\"/></cellXfs>'\n                    '</styleSheet>'\n                )\n\n                app_xml = (\n                    '<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\\n'\n                    '<Properties xmlns=\"http://schemas.openxmlformats.org/officeDocument/2006/extended-properties\">'\n                    '<Application>SnapLogic</Application></Properties>'\n                )\n\n                core_xml = (\n                    '<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\\n'\n                    '<cp:coreProperties xmlns:cp=\"http://schemas.openxmlformats.org/package/2006/metadata/core-properties\" '\n                    'xmlns:dc=\"http://purl.org/dc/elements/1.1/\"><dc:creator>SnapLogic</dc:creator></cp:coreProperties>'\n                )\n\n                baos= ByteArrayOutputStream()\n                zos = ZipOutputStream(baos)\n\n                def write_zip_entry(name, content):\n                    try:\n                        entry = ZipEntry(name)\n                        zos.putNextEntry(entry)\n                        data = content.encode(\"utf-8\")\n                        zos.write(data, 0, len(data))\n                        zos.closeEntry()\n                    except Exception as ze:\n                        self.log.error(\"Error writing zip entry {}: {}\".format(name, str(ze)))\n                        raise ze\n\n                write_zip_entry(\"[Content_Types].xml\", content_types_xml)\n                write_zip_entry(\"_rels/.rels\", rels_xml)\n                write_zip_entry(\"xl/workbook.xml\", workbook_xml)\n                write_zip_entry(\"xl/_rels/workbook.xml.rels\", workbook_rels_xml)\n                write_zip_entry(\"xl/worksheets/sheet1.xml\", sheet1_xml)\n                write_zip_entry(\"xl/worksheets/sheet2.xml\", sheet2_xml)\n                write_zip_entry(\"xl/styles.xml\", styles_xml)\n                write_zip_entry(\"docProps/app.xml\", app_xml)\n                write_zip_entry(\"docProps/core.xml\", core_xml)\n\n                zos.finish()\n                zos.close()\n\n                xlsx_bytes = baos.toByteArray()\n                b64_str = Base64.getEncoder().encodeToString(xlsx_bytes)\n\n                self.output.write({\n                    \"status\": \"success\",\n                    \"file\": \"weather_output.xlsx\",\n                    \"rows_written\": len(records),\n                    \"rows_read\": len(read_log),\n                    \"content\": b64_str\n                })\n\n            except Exception as zip_err:\n                self.log.error(\"Error building/writing ZIP: \" + str(zip_err))\n                self.error.write({\"status\": \"error\", \"stage\": \"zip_write\", \"message\": str(zip_err)})\n                return\n\n        except Exception as outer_err:\n            self.log.error(\"Unhandled error in execute(): \" + str(outer_err))\n            self.error.write({\"status\": \"error\", \"stage\": \"outer\", \"message\": str(outer_err)})\n\n    def cleanup(self):\n        pass\n\nhook = ExcelGeneratorHook(input, output, error, log)\n"
                    },
                    "executable_during_suggest": {
                        "value": false
                    },
                    "execution_mode": {
                        "value": "Validate & Execute"
                    },
                    "language": {
                        "value": "Python"
                    }
                }
            }
        },
