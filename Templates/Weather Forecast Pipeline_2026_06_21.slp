write_3-UNKNOWN","class_id":"com-snaplogic-snaps-binary-write","class_version":3,"instance_fqid":"a01db6b4-3667-4380-b981-1756ae6b3f27_2","instance_id":"a01db6b4-3667-4380-b981-1756ae6b3f27","instance_version":2,"property_map":{"account":{"account_ref":{"value":{}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{},"input":{"input0":{"label":{"value":"input0"},"view_type":{"value":"binary"}}},"info":{"notes":{"value":""},"label":{"value":"CSV File Writer"}},"settings":{"executable_during_suggest":{"value":false},"filename":{"value":"'weather_output_' + _postcode + '.csv'","expression":true},"preventURLEncoding":{"value":false},"fileAction":{"value":"OVERWRITE"},"retries":{"value":0,"expression":true},"retryInterval":{"value":1,"expression":true},"UserPermissionsKey":{"value":[]},"flushIntervalKb":{"value":-1},"advancedProperties":{"value":[]},"cannedAcls":{"value":"None"}}},"class_build_tag":"UNKNOWN"},"5fb8c90f-9682-43d8-947e-8b0ad886994d":{"class_fqid":"com-snaplogic-snaps-script-script_2-UNKNOWN","class_id":"com-snaplogic-snaps-script-script","class_version":2,"instance_fqid":"5fb8c90f-9682-43d8-947e-8b0ad886994d_13","instance_id":"5fb8c90f-9682-43d8-947e-8b0ad886994d","instance_version":13,"property_map":{"account":{"account_ref":{"value":{}}},"error":{"error0":{"view_type":{"value":"document"},"label":{"value":"error0"}},"error_behavior":{"value":"fail"}},"output":{"output0":{"label":{"value":"output0"},"view_type":{"value":"document"}}},"input":{"input0":{"label":{"value":"input0"},"view_type":{"value":"document"}}},"info":{"notes":{"value":""},"label":{"value":"Python Excel Generator"}},"settings":{"language":{"value":"Python"},"editable_content":{"value":"from com.snaplogic.scripting.language import ScriptHook\nfrom java.io import ByteArrayOutputStream\nfrom java.util.zip import ZipOutputStream, ZipEntry\nfrom java.util import Base64\n\nclass ExcelGeneratorHook(ScriptHook):\n    def __init__(self, input, output, error, log):\n        self.input = input\n        self.output = output\n        self.error = error\n        self.log = log\n\n    def _escape_xml(self, val):\n        s = unicode(val) if val is not None else u\"\"\n        s = s.replace(u\"&\", u\"&amp;\")\n        s = s.replace(u\"<\", u\"&lt;\")\n        s = s.replace(u\">\", u\"&gt;\")\n        s = s.replace(u'\"', u\"&quot;\")\n        s = s.replace(u\"'\", u\"&apos;\")\n        return s\n\n    def _write_zip_entry(self, zos, name, content):\n        entry = ZipEntry(name)\n        zos.putNextEntry(entry)\n        data = content.encode(\"utf-8\")\n        zos.write(data, 0, len(data))\n        zos.closeEntry()\n\n    def execute(self):\n        try:\n            records = []\n            for doc in self.input:\n                records.append(doc)\n\n            self.log.info(\"Records received: {}\".format(len(records)))\n\n            if not records:\n                self.output.write({\n                    \"status\": \"error\",\n                    \"message\": \"No input records received\",\n                    \"rows_written\": 0\n                })\n                return\n\n            headers = [\"Hour\", \"Temperature\"]\n\n            # ---- Build sheet1.xml rows ----\n            row_xml_parts = []\n\n            # Header row (row 1, style index 0)\n            header_cells = []\n            for col_idx, hdr in enumerate(headers):\n                col_letter = chr(ord('A') + col_idx)\n                cell_ref = \"{}1\".format(col_letter)\n                escaped = self._escape_xml(hdr)\n                header_cells.append(\n                    u'<c r=\"{}\" s=\"0\" t=\"inlineStr\"><is><t>{}</t></is></c>'.format(cell_ref, escaped)\n                )\n            row_xml_parts.append(\n                u'<row r=\"1\">{}</row>'.format(u\"\".join(header_cells))\n            )\n\n            # Data rows\n            for row_idx, record in enumerate(records, start=2):\n                is_even = (row_idx % 2 == 0)\n                cells = []\n                for col_idx, hdr in enumerate(headers):\n                    col_letter = chr(ord('A') + col_idx)\n                    cell_ref = \"{}{}\".format(col_letter, row_idx)\n                    val = record.get(hdr)\n\n                    if hdr == \"Temperature\":\n                        # Numeric cell with 0.00 format\n                        # Even rows: style 3, Odd rows: style 4\n                        style_idx = 3 if is_even else 4\n                        try:\n                            num_val = float(str(val)) if val is not None else 0.0\n                            cells.append(\n                                u'<c r=\"{}\" s=\"{}\"><v>{}</v></c>'.format(\n                                    cell_ref, style_idx, num_val\n                                )\n                            )\n                        except Exception:\n                            escaped = self._escape_xml(val)\n                            cells.append(\n                                u'<c r=\"{}\" s=\"{}\" t=\"inlineStr\"><is><t>{}</t></is></c>'.format(\n                                    cell_ref, style_idx, escaped\n                                )\n                            )\n                    else:\n                        # Hour column: inline string\n                        # Even rows: style 1, Odd rows: style 2\n                        style_idx = 1 if is_even else 2\n                        escaped = self._escape_xml(val)\n                        cells.append(\n                            u'<c r=\"{}\" s=\"{}\" t=\"inlineStr\"><is><t>{}</t></is></c>'.format(\n                                cell_ref, style_idx, escaped\n                            )\n                        )\n\n                row_xml_parts.append(\n                    u'<row r=\"{}\">{}</row>'.format(row_idx, u\"\".join(cells))\n                )\n\n            rows_xml = u\"\".join(row_xml_parts)\n\n            # ---- XML parts ----\n\n            content_types_xml = u\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n<Types xmlns=\"http://schemas.openxmlformats.org/package/2006/content-types\">\n  <Default Extension=\"rels\" ContentType=\"application/vnd.openxmlformats-package.relationships+xml\"/>\n  <Default Extension=\"xml\" ContentType=\"application/xml\"/>\n  <Override PartName=\"/xl/workbook.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet.main+xml\"/>\n  <Override PartName=\"/xl/worksheets/sheet1.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.worksheet+xml\"/>\n  <Override PartName=\"/xl/styles.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.spreadsheetml.styles+xml\"/>\n  <Override PartName=\"/docProps/app.xml\" ContentType=\"application/vnd.openxmlformats-officedocument.extended-properties+xml\"/>\n  <Override PartName=\"/docProps/core.xml\" ContentType=\"application/vnd.openxmlformats-package.core-properties+xml\"/>\n</Types>\"\"\"\n\n            rels_xml = u\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n<Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\">\n  <Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/officeDocument\" Target=\"xl/workbook.xml\"/>\n  <Relationship Id=\"rId2\" Type=\"http://schemas.openxmlformats.org/package/2006/relationships/metadata/core-properties\" Target=\"docProps/core.xml\"/>\n  <Relationship Id=\"rId3\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/extended-properties\" Target=\"docProps/app.xml\"/>\n</Relationships>\"\"\"\n\n            workbook_xml = u\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n<workbook xmlns=\"http://schemas.openxmlformats.org/spreadsheetml/2006/main\"\n          xmlns:r=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships\">\n  <sheets>\n    <sheet name=\"Weather Data\" sheetId=\"1\" r:id=\"rId1\"/>\n  </sheets>\n</workbook>\"\"\"\n\n            workbook_rels_xml = u\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n<Relationships xmlns=\"http://schemas.openxmlformats.org/package/2006/relationships\">\n  <Relationship Id=\"rId1\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/worksheet\" Target=\"worksheets/sheet1.xml\"/>\n  <Relationship Id=\"rId2\" Type=\"http://schemas.openxmlformats.org/officeDocument/2006/relationships/styles\" Target=\"styles.xml\"/>\n</Relationships>\"\"\"\n\n            # styles.xml\n            # numFmts: id=164 -> \"0.00\"\n            # fonts: 0=default, 1=bold white\n            # fills: 0=none(required), 1=gray(required), 2=blue header, 3=light blue even, 4=white odd\n            # borders: 0=none, 1=thin all sides\n            # cellStyleXfs: 0=default\n            # cellXfs:\n            #   0 = header  (font1, fill2, border1, center horiz+vert)\n            #   1 = even default (font0, fill3, border1, center)\n            #   2 = odd default  (font0, fill4, border1, center)\n            #   3 = even temp    (font0, fill3, border1, center, numFmt 164)\n            #   4 = odd temp     (font0, fill4, border1, center, numFmt 164)\n            #   5 = even hour    (font0, fill3, border1, center)\n            #   6 = odd hour     (font0, fill4, border1, center)\n\n            styles_xml = u\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n<styleSheet xmlns=\"http://schemas.openxmlformats.org/spreadsheetml/2006/main\">\n  <numFmts count=\"1\">\n    <numFmt numFmtId=\"164\" formatCode=\"0.00\"/>\n  </numFmts>\n  <fonts count=\"2\">\n    <font>\n      <sz val=\"11\"/>\n      <name val=\"Calibri\"/>\n    </font>\n    <font>\n      <b/>\n      <sz val=\"11\"/>\n      <color rgb=\"FFFFFFFF\"/>\n      <name val=\"Calibri\"/>\n    </font>\n  </fonts>\n  <fills count=\"5\">\n    <fill><patternFill patternType=\"none\"/></fill>\n    <fill><patternFill patternType=\"gray125\"/></fill>\n    <fill>\n      <patternFill patternType=\"solid\">\n        <fgColor rgb=\"FF4472C4\"/>\n        <bgColor indexed=\"64\"/>\n      </patternFill>\n    </fill>\n    <fill>\n      <patternFill patternType=\"solid\">\n        <fgColor rgb=\"FFDCE6F1\"/>\n        <bgColor indexed=\"64\"/>\n      </patternFill>\n    </fill>\n    <fill>\n      <patternFill patternType=\"solid\">\n        <fgColor rgb=\"FFFFFFFF\"/>\n        <bgColor indexed=\"64\"/>\n      </patternFill>\n    </fill>\n  </fills>\n  <borders count=\"2\">\n    <border>\n      <left/><right/><top/><bottom/><diagonal/>\n    </border>\n    <border>\n      <left style=\"thin\"><color auto=\"1\"/></left>\n      <right style=\"thin\"><color auto=\"1\"/></right>\n      <top style=\"thin\"><color auto=\"1\"/></top>\n      <bottom style=\"thin\"><color auto=\"1\"/></bottom>\n      <diagonal/>\n    </border>\n  </borders>\n  <cellStyleXfs count=\"1\">\n    <xf numFmtId=\"0\" fontId=\"0\" fillId=\"0\" borderId=\"0\"/>\n  </cellStyleXfs>\n  <cellXfs count=\"7\">\n    <xf numFmtId=\"0\" fontId=\"1\" fillId=\"2\" borderId=\"1\" xfId=\"0\" applyFont=\"1\" applyFill=\"1\" applyBorder=\"1\" applyAlignment=\"1\">\n      <alignment horizontal=\"center\" vertical=\"center\"/>\n    </xf>\n    <xf numFmtId=\"0\" fontId=\"0\" fillId=\"3\" borderId=\"1\" xfId=\"0\" applyFill=\"1\" applyBorder=\"1\" applyAlignment=\"1\">\n      <alignment horizontal=\"center\" vertical=\"center\"/>\n    </xf>\n    <xf numFmtId=\"0\" fontId=\"0\" fillId=\"4\" borderId=\"1\" xfId=\"0\" applyFill=\"1\" applyBorder=\"1\" applyAlignment=\"1\">\n      <alignment horizontal=\"center\" vertical=\"center\"/>\n    </xf>\n    <xf numFmtId=\"164\" fontId=\"0\" fillId=\"3\" borderId=\"1\" xfId=\"0\" applyNumberFormat=\"1\" applyFill=\"1\" applyBorder=\"1\" applyAlignment=\"1\">\n      <alignment horizontal=\"center\" vertical=\"center\"/>\n    </xf>\n    <xf numFmtId=\"164\" fontId=\"0\" fillId=\"4\" borderId=\"1\" xfId=\"0\" applyNumberFormat=\"1\" applyFill=\"1\" applyBorder=\"1\" applyAlignment=\"1\">\n      <alignment horizontal=\"center\" vertical=\"center\"/>\n    </xf>\n    <xf numFmtId=\"0\" fontId=\"0\" fillId=\"3\" borderId=\"1\" xfId=\"0\" applyFill=\"1\" applyBorder=\"1\" applyAlignment=\"1\">\n      <alignment horizontal=\"center\" vertical=\"center\"/>\n    </xf>\n    <xf numFmtId=\"0\" fontId=\"0\" fillId=\"4\" borderId=\"1\" xfId=\"0\" applyFill=\"1\" applyBorder=\"1\" applyAlignment=\"1\">\n      <alignment horizontal=\"center\" vertical=\"center\"/>\n    </xf>\n  </cellXfs>\n</styleSheet>\"\"\"\n\n            sheet1_xml = u\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n<worksheet xmlns=\"http://schemas.openxmlformats.org/spreadsheetml/2006/main\">\n  <sheetViews>\n    <sheetView workbookViewId=\"0\">\n      <pane ySplit=\"1\" topLeftCell=\"A2\" activePane=\"bottomLeft\" state=\"frozen\"/>\n    </sheetView>\n  </sheetViews>\n  <sheetData>\n    {}\n  </sheetData>\n</worksheet>\"\"\".format(rows_xml)\n\n            app_xml = u\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n<Properties xmlns=\"http://schemas.openxmlformats.org/officeDocument/2006/extended-properties\">\n  <Application>SnapLogic</Application>\n</Properties>\"\"\"\n\n            core_xml = u\"\"\"<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n<cp:coreProperties xmlns:cp=\"http://schemas.openxmlformats.org/package/2006/metadata/core-properties\"\n  xmlns:dc=\"http://purl.org/dc/elements/1.1/\">\n  <dc:title>Weather Data</dc:title>\n</cp:coreProperties>\"\"\"\n\n            # ---- Build ZIP (xlsx) in memory ----\n            baos = ByteArrayOutputStream()\n            zos = ZipOutputStream(baos)\n\n            self._write_zip_entry(zos, \"[Content_Types].xml\", content_types_xml)\n            self._write_zip_entry(zos, \"_rels/.rels\", rels_xml)\n            self._write_zip_entry(zos, \"xl/workbook.xml\", workbook_xml)\n            self._write_zip_entry(zos, \"xl/_rels/workbook.xml.rels\", workbook_rels_xml)\n            self._write_zip_entry(zos, \"xl/worksheets/sheet1.xml\", sheet1_xml)\n            self._write_zip_entry(zos, \"xl/styles.xml\", styles_xml)\n            self._write_zip_entry(zos, \"docProps/app.xml\", app_xml)\n            self._write_zip_entry(zos, \"docProps/core.xml\", core_xml)\n\n            zos.finish()\n            zos.close()\n\n            xlsx_bytes = baos.toByteArray()\n            b64_str = Base64.getEncoder().encodeToString(xlsx_bytes)\n\n            self.output.write({\n                \"status\": \"success\",\n                \"file\": \"weather_output.xlsx\",\n                \"rows_written\": len(records),\n                \"content_base64\": b64_str\n            })\n\n        except Exception as e:\n            self.error.write({\n                \"status\": \"error\",\n                \"message\": str(e)\n            })\n\n    def cleanup(self):\n        pass\n\nhook = ExcelGeneratorHook(input, output, error, log)\n"},"executable_during_suggest":{"value":false},"execution_mode":{"value":"Validate & Execute"}}},"class_build_tag":"UNKNOWN"}},"path_id":"/integrate-workshop/projects/Daniel_20260617","path_snode":"6a32c50780e8ceb9ba280202"}