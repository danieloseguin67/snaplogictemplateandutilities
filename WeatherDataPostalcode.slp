                "output": {
                    "output0": {
                        "label": {
                            "value": "output0"
                        },
                        "view_type": {
                            "value": "document"
                        }
                    }
                },
                "settings": {
                    "editable_content": {
                        "value": "\nclass Transform(object):\n    def __init__(self):\n        self.rows = []\n        self.headers = None\n\n    def process(self, doc):\n        if self.headers is None:\n            self.headers = list(doc.keys())\n        self.rows.append([doc.get(h, '') for h in self.headers])\n        return []\n\n    def post_process(self):\n        import sys\n        try:\n            import openpyxl\n            from openpyxl import Workbook\n        except ImportError:\n            yield {'error': 'openpyxl is not available in this environment'}\n            return\n\n        wb = Workbook()\n        ws = wb.active\n        ws.title = 'Weather Data'\n\n        if self.headers:\n            ws.append(self.headers)\n\n        for row in self.rows:\n            ws.append(row)\n\n        filename = '/tmp/weather_output_excelMethod.xlsx'\n        wb.save(filename)\n\n        yield {\n            'filename': filename,\n            'rows_written': len(self.rows),\n            'status': 'success'\n        }\n"
                    },
                    "executable_during_suggest": {
                        "value": true
                    },
                    "language": {
                        "value": "Python"
                    }
                }
            }
